# PromptForge Environment Variables
# Copy this file as .env and fill in your values

# === LOCAL DEVELOPMENT ===
# Use backend proxy (run: cd server && npm run dev)
VITE_USE_BACKEND=true
VITE_BACKEND_URL=http://localhost:3001

# === SUPABASE (Auth + Database) ===
# Get from: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# === VERCEL PRODUCTION (set in Vercel Dashboard, NOT here) ===
# OPENROUTER_API_KEY=sk-or-v1-...  (server-only, never expose to frontend)
